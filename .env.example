# imgproxy environment variables
# Copy this file to .env and adjust as needed

# Signing keys (leave empty to disable signed URLs)
IMGPROXY_KEY=
IMGPROXY_SALT=

# Bind address
IMGPROXY_BIND=0.0.0.0:8080

# Local filesystem root for local:// sources
IMGPROXY_LOCAL_FILESYSTEM_ROOT=/assets

# Allowed sources
IMGPROXY_ALLOWED_SOURCES=local://,http://,https://

# Processing timeout in seconds
IMGPROXY_TIMEOUT=180

# Logging
IMGPROXY_LOG_LEVEL=info

# ETag support
IMGPROXY_USE_ETAG=true
